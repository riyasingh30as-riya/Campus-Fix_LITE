# Copy this file to .env and fill in your real values

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/campusfix?retryWrites=true&w=majority

# JWT secret - use a long random string in production
JWT_SECRET=replace_this_with_a_long_random_secret

# Port the API server listens on. 5050 avoids the macOS AirPlay service, which
# commonly occupies port 5000.
PORT=5050

# Comma-separated list of allowed frontend origins (CORS)
CLIENT_ORIGIN=http://localhost:5173

# One-time admin bootstrap (used by npm run seed:admin)
ADMIN_EMAIL=demo.admin@campusfix.edu
ADMIN_PASSWORD=CampusFix123!
ADMIN_NAME=Campus Admin
